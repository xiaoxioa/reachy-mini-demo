# reachy-mini-demo 配置模板
# 复制此文件为 .env 并填写你的值：
#   cp .env.example .env
# .env 不会被提交到 git（已在 .gitignore 中排除）。

# ─────────────────────────────────────────────
#  必填：阿里云百炼 API Key
#  用于 Qwen-Omni 实时对话 + Qwen-VL 看图描述
#  在 https://bailian.console.aliyun.com/ 获取
# ─────────────────────────────────────────────
DASHSCOPE_API_KEY=sk-your-key-here

# ─────────────────────────────────────────────
#  模型选择
#  取消注释并修改即可切换模型，不需要改代码
# ─────────────────────────────────────────────

# 实时对话模型（全双工语音）
# REALTIME_MODEL=qwen3.5-omni-plus-realtime

# 视觉理解模型（看图/指向识别）
# VISION_MODEL=qwen3.5-omni-plus

# 退出摘要模型
# SUMMARY_MODEL=qwen-turbo

# ─────────────────────────────────────────────
#  网络 / 离线
# ─────────────────────────────────────────────

# 禁止 HuggingFace 网络访问（舞蹈动作库不需要在线下载，避免启动时卡住）
HF_HUB_OFFLINE=1

# 代理绕过（防止本地 API 请求走系统代理）
NO_PROXY=localhost,127.0.0.1,::1

# ─────────────────────────────────────────────
#  调试模式（开发用，生产环境保持注释）
# ─────────────────────────────────────────────

# 关闭语音功能，仅测试视觉特性（人脸跟踪 / 手势指向 / 逗它互动）
# 跳过麦克风、扬声器、Qwen-Omni 连接；状态机和头部跟踪照常运行
# 启动时不再要求输入 DASHSCOPE_API_KEY
# NO_VOICE=1

# 视觉调试流：在浏览器实时查看机器人摄像头画面 + 检测标注
#   打开 http://localhost:7654 即可（支持多标签页同时查看）
#   画面说明：
#     蓝框  = 检测到的人脸（框高 = 人脸高度占比，越近越大）
#     绿框  = 有效手（score ≥ 0.6，认为是真手，可触发逗它互动）
#     黄框  = 低置信度手（可能是背景误检，不触发行为）
#     手框角落标注 = "size=0.45 score=0.91 [fist]"（尺寸/置信度/手势）
#     左上角 = 状态机状态（IDLE/ENGAGING/TRACKING/PLAYING…）+ 头部目标方向
#   头部仍会跟随人脸正常运动，调试流不影响机器人行为
# VIS_DEBUG=1
# VIS_DEBUG_PORT=7654   # 默认 7654，改此行可修改端口

# 仿真模式下使用 Mac 摄像头代替 MuJoCo 虚拟摄像头
# MuJoCo 仿真场景是空棋盘格，虚拟摄像头无法拍到真实人脸
# 用 --sim 启动 daemon 时取消注释，让视觉子进程从 Mac 摄像头取帧
# 真机运行时无需此项
# USE_WEBCAM=1
